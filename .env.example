# Скопируй этот файл в .env и заполни реальными значениями.
# Файл .env в git НЕ коммитится.

# === Google Sheets ===
# ID таблицы — из URL: https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEETS_ID=1abc...xyz

# Путь к JSON-файлу с ключами Service Account
# Скачивается из Google Cloud Console при создании сервисного аккаунта.
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./google_credentials.json

# === Polza.ai (LLM) ===
POLZA_API_KEY=
POLZA_BASE_URL=https://api.polza.ai/v1
LLM_MODEL=gpt-4o-mini

# === Telegram ===
TELEGRAM_BOT_TOKEN=
# Через запятую — ID разрешённых пользователей. Узнать ID: @userinfobot
TELEGRAM_ALLOWED_USER_IDS=12345678,87654321

# === Реквизиты официальной ТТК (.docx) ===
# Необязательно: если не заданы — берутся дефолты сети «Тим Кук» из src/config.py.
TTK_ORG_NAME=ООО «Гастрономия»
TTK_DIRECTOR_POSITION=Генеральный директор
TTK_TR_TS_NUMBER=021/2011

# === Мониторинг конкурентов ===
# ОТДЕЛЬНАЯ таблица под отчёты (не рабочая таблица шефа!).
# Создать пустую Google-таблицу и расшарить на email сервисного аккаунта (роль «Редактор»).
# Пусто/не задано → экспорт в Sheets выключен, всё остальное работает.
COMPETITORS_SHEETS_ID=
# День/время еженедельной проверки (день: mon/tue/.../sun, время МСК)
COMPETITORS_CHECK_DAY=mon
COMPETITORS_CHECK_HOUR=3
COMPETITORS_CHECK_MINUTE=30
# Порог существенного изменения цены: max(процент от старой цены, рубли)
COMPETITORS_PRICE_THRESHOLD_PCT=10
COMPETITORS_PRICE_THRESHOLD_RUB=30
